---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="ALEX-1 · Deep Pearl"
  description="An assistant that runs on the device, keeps personal data local, and learns from everyday use."
>
  <article class="thread-page wrap">
    <a class="back" href="/">
      <span aria-hidden="true">&larr;</span>
      <span>Deep Pearl</span>
    </a>

    <div class="meta-row">
      <span class="tag tag-active">Active prototype</span>
    </div>
    <h1>ALEX-1</h1>
    <p class="lede">An assistant that runs on the device, keeps personal data local, and learns from everyday use.</p>

    <div class="research-groups">
      <section class="research-group" aria-labelledby="g-alex">
        <h2 id="g-alex">Research topics</h2>
        <ul class="studying-list">
          <li>representation learning</li>
          <li>interpretability</li>
          <li>adaptive computation</li>
          <li>edge deployment</li>
          <li>robotic integration</li>
        </ul>
      </section>
    </div>
  </article>
</Layout>
