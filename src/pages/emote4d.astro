---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="EMOTE4D · Deep Pearl"
  description="On device computer vision that detects falls in eldercare without sending video away."
>
  <article class="thread-page wrap">
    <a class="back" href="/">
      <span aria-hidden="true">&larr;</span>
      <span>Deep Pearl</span>
    </a>

    <div class="meta-row">
      <span class="tag tag-pilot">In pilot</span>
    </div>
    <h1>EMOTE4D</h1>
    <p class="lede">On device computer vision that detects falls in eldercare without sending video away.</p>

    <div class="research-groups">
      <section class="research-group" aria-labelledby="g-emote">
        <h2 id="g-emote">Research topics</h2>
        <ul class="studying-list">
          <li>representation learning</li>
          <li>adaptive computation</li>
          <li>edge deployment</li>
        </ul>
      </section>
    </div>
  </article>
</Layout>
