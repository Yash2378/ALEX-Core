---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="EMOTE4D · Deep Pearl AI"
  description="EMOTE4D is on-device computer vision that detects falls in eldercare without sending video away — skeleton-only processing on Raspberry Pi hardware, in live pilot."
  chapter="05"
>
  <section class="page-hero">
    <div class="wrap">
      <a class="back" href="/">
        <span aria-hidden="true">&larr;</span>
        <span>Deep Pearl AI</span>
      </a>
      <div class="meta-row">
        <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Edge intelligence</p>
        <span class="tag tag-pilot">In pilot</span>
      </div>
      <h1>EMOTE4D</h1>
      <p class="lede">
        On-device computer vision that detects falls in eldercare — without
        sending video anywhere. Skeleton-only processing on Raspberry Pi
        hardware, running in a live pilot.
      </p>
      <div class="hero-links">
        <a class="btn btn-primary" href="https://emote4d.com" rel="noopener">emote4d.com</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <figure class="figure" data-accrete>
        <div class="plate e4d-plate">
          <canvas id="e4d-canvas" aria-hidden="true"></canvas>
          <span class="plate-label" style="top:14px;left:16px">What the camera sees</span>
          <span class="plate-label e4d-center" style="top:14px;left:50%">The device</span>
          <span class="plate-label" style="top:14px;right:16px">What leaves the device</span>
          <span class="plate-label red" style="bottom:14px;left:16px">Raw feed · does not leave</span>
          <span class="plate-label" style="bottom:14px;left:calc(50% + 16px)">17 keypoints · no image data</span>
          <span class="plate-label e4d-gate" id="e4d-gate1">Gate 1 · motion trigger</span>
          <span class="plate-label e4d-gate" id="e4d-gate2">Gate 2 · pose confirm</span>
          <div class="e4d-chip" id="e4d-chip" role="status"></div>
        </div>
        <figcaption class="figcap">
          <span><span class="fig-no">FIG. 4</span> — PIXELS STOP HERE</span>
          <span class="fig-note">What leaves the home is an alert, not a recording.</span>
        </figcaption>
        <div class="plate-controls">
          <button type="button" class="plate-btn armed" id="e4d-fall">Simulate a fall</button>
          <span class="e4d-status" id="e4d-status" aria-hidden="true">PIPELINE · NOMINAL</span>
        </div>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="prose" data-accrete>
        <h2>The problem</h2>
        <p>
          Falls are the leading cause of fatal injury for adults over 65, and
          the dominant solutions fail for one human reason: pendants and
          wearables only work if they're worn. Camera systems remove the
          compliance problem but create a worse one — nobody wants streaming
          video of their bedroom leaving the house.
        </p>
        <p>
          EMOTE4D resolves both. <strong>The camera's pixels never leave the
          device.</strong> Video is reduced to a skeleton — pose landmarks, not
          images — on the device itself, and every downstream decision runs on
          that skeleton. What leaves the home is an alert, not a recording.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <header class="section-header" data-accrete>
        <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Architecture</p>
        <h2>A pipeline that doesn't trust itself</h2>
      </header>
      <ol class="steps" data-accrete>
        <li>
          <div>
            <h3>Pose, on the device</h3>
            <p>
              A commodity camera feeds an on-device pose estimator. From that
              point forward the system reasons about biomechanics — joint
              positions, velocities, torso angle, ground proximity — never raw
              pixels.
            </p>
          </div>
        </li>
        <li>
          <div>
            <h3>Sanity gates between every stage</h3>
            <p>
              Compositional vision systems fail when one stage blindly trusts
              another. EMOTE4D puts explicit gates at each boundary: is this
              frame usable, is this skeleton real or hallucinated, are these
              landmarks observed or extrapolated? Phantom poses are killed
              upstream, before they can look like falls downstream.
            </p>
          </div>
        </li>
        <li>
          <div>
            <h3>Two-stage fall confirmation</h3>
            <p>
              A fast first stage flags candidate falls from biomechanical
              features grounded in the physics of falling. A stricter second
              stage verifies geometry and stillness before anything is allowed
              to alert — recall first, then precision.
            </p>
          </div>
        </li>
        <li>
          <div>
            <h3>Honest failure modes</h3>
            <p>
              When the system cannot see — darkness, occlusion, a covered
              sensor — it says so rather than guessing. A monitoring system
              that fails silently is worse than none; families are told when
              coverage pauses.
            </p>
          </div>
        </li>
        <li>
          <div>
            <h3>Hardened on production hardware</h3>
            <p>
              Every operating number is measured on the deployed device —
              Raspberry Pi 5 with an infrared-capable camera — in real rooms
              with real lighting, through multi-day continuous runs. Lab
              results are treated as hypotheses, not claims.
            </p>
          </div>
        </li>
      </ol>

      <div class="callout" data-accrete>
        <p>
          <strong>Where it stands.</strong> EMOTE4D is in a live overnight
          pilot deployment, iterating on the gate architecture through
          continuous multi-day runs and preparing for in-home family pilots in
          Manitoba. The engineering record — forty-plus architecture decision
          records — documents every failure mode found and fix shipped.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <header class="section-header" data-accrete>
        <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Design commitments</p>
        <h2>What the system promises</h2>
      </header>
      <dl class="facts" data-accrete>
        <div class="fact">
          <dt>Privacy</dt>
          <dd>Skeleton-only processing on the device. No video storage, no video transmission, ever.</dd>
        </div>
        <div class="fact">
          <dt>Physics first</dt>
          <dd>Detection grounded in the biomechanics of falling — features that transfer across cameras, rooms, and skeleton formats.</dd>
        </div>
        <div class="fact">
          <dt>Affordable</dt>
          <dd>Commodity edge hardware, not proprietary sensors — built to be deployable in ordinary homes.</dd>
        </div>
      </dl>

      <div class="now-band" data-accrete>
        <p class="label">Research threads in play</p>
        <ul class="pill-list">
          <li>representation learning</li>
          <li>adaptive computation</li>
          <li>edge deployment</li>
          <li>privacy-preserving vision</li>
          <li>safety-critical ML</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .e4d-plate {
    aspect-ratio: 16 / 9;
  }

  .e4d-center {
    transform: translateX(-50%);
  }

  /* the two confirmation gates — permanently visible architecture */
  .e4d-gate {
    top: 50%;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: var(--faint);
    opacity: 0.55;
    transition: color 280ms ease, opacity 280ms ease;
  }

  #e4d-gate1 {
    left: calc(86.5% + 6px);
  }

  #e4d-gate2 {
    left: calc(93.5% + 6px);
  }

  .e4d-gate.lit {
    color: var(--pearl-a);
    opacity: 1;
  }

  /* the alert chip — the only thing that ever leaves the home */
  .e4d-chip {
    position: absolute;
    bottom: 14px;
    right: 14px;
    z-index: 4;
    max-width: min(320px, 70%);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.45;
    letter-spacing: 0.06em;
    color: var(--alert);
    border: 1px solid rgba(216, 160, 122, 0.55);
    border-radius: 6px;
    background: rgba(7, 8, 10, 0.88);
    padding: 8px 12px;
    transform: translateX(calc(100% + 28px));
    transition: transform 420ms var(--ease-press);
    pointer-events: none;
  }

  .e4d-chip.show {
    transform: translateX(0);
  }

  .e4d-status {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
  }

  #e4d-fall:disabled {
    opacity: 0.55;
    cursor: default;
  }

  @media (max-width: 700px) {
    .e4d-plate {
      aspect-ratio: 4 / 3;
    }

    .e4d-plate .plate-label {
      font-size: 9px;
      letter-spacing: 0.08em;
    }

    /* not enough width for three top labels + two bottom captions */
    .e4d-center,
    .e4d-plate .plate-label[style*="bottom"] {
      display: none;
    }

    .e4d-gate {
      font-size: 8.5px;
    }

    .e4d-chip {
      font-size: 10px;
      max-width: 62%;
    }
  }
</style>

<script>
  import { pearlLUT, lutColor, makeSim, glowSprite, reducedMotion } from '../lib/nacre.js';

  function initEmote4d() {
    const c = document.getElementById('e4d-canvas');
    if (!c || c.dataset.init) return;
    c.dataset.init = '1';

    const lut = pearlLUT(undefined, 256, 2.2);
    const gate1El = document.getElementById('e4d-gate1');
    const gate2El = document.getElementById('e4d-gate2');
    const chipEl = document.getElementById('e4d-chip');
    const statusEl = document.getElementById('e4d-status');
    const btn = document.getElementById('e4d-fall');
    const CHIP_TEXT = 'ALERT SENT — no pixels left this home';

    /* -----------------------------------------------------------
       The pose model. 17 joints, [x, y] each, normalized: x is
       forward offset from center, y is height above ground, both
       in units of total figure height. Joint order:
       0 head, 1 neck, 2 rSho, 3 lSho, 4 rElb, 5 lElb, 6 rWri,
       7 lWri, 8 hipC, 9 rHip, 10 lHip, 11 rKne, 12 lKne,
       13 rAnk, 14 lAnk, 15 rToe, 16 lToe.
       BOTH halves of the plate draw from this identical data.
       ----------------------------------------------------------- */

    /* walk cycle — 8 baked keyframes, right heel-strike at frame 0 */
    const WALK = [
      [0.025,0.927, 0.012,0.842, 0.015,0.814, -0.015,0.814,
       -0.040,0.655, 0.050,0.655, -0.095,0.520, 0.100,0.535,
       0.000,0.512, 0.022,0.517, -0.022,0.507,
       0.080,0.290, -0.050,0.310, 0.150,0.030, -0.150,0.060,
       0.235,0.030, -0.075,0.020],
      [0.025,0.937, 0.012,0.852, 0.015,0.824, -0.015,0.824,
       -0.025,0.660, 0.030,0.660, -0.060,0.510, 0.065,0.520,
       0.000,0.522, 0.022,0.527, -0.022,0.517,
       0.040,0.285, 0.020,0.340, 0.080,0.020, -0.060,0.120,
       0.165,0.005, 0.000,0.085],
      [0.025,0.945, 0.012,0.860, 0.015,0.832, -0.015,0.832,
       0.005,0.662, 0.005,0.662, 0.010,0.500, 0.012,0.502,
       0.000,0.530, 0.022,0.535, -0.022,0.525,
       0.000,0.280, 0.080,0.330, 0.000,0.020, 0.060,0.110,
       0.085,0.005, 0.125,0.085],
      [0.025,0.937, 0.012,0.852, 0.015,0.824, -0.015,0.824,
       0.030,0.660, -0.025,0.658, 0.060,0.515, -0.058,0.512,
       0.000,0.522, 0.022,0.527, -0.022,0.517,
       -0.040,0.285, 0.100,0.300, -0.090,0.030, 0.140,0.050,
       -0.010,0.005, 0.225,0.045],
      [0.025,0.927, 0.012,0.842, 0.015,0.814, -0.015,0.814,
       0.050,0.655, -0.040,0.655, 0.100,0.535, -0.095,0.520,
       0.000,0.512, 0.022,0.517, -0.022,0.507,
       -0.050,0.310, 0.080,0.290, -0.150,0.060, 0.150,0.030,
       -0.075,0.020, 0.235,0.030],
      [0.025,0.937, 0.012,0.852, 0.015,0.824, -0.015,0.824,
       0.030,0.660, -0.025,0.660, 0.065,0.520, -0.060,0.510,
       0.000,0.522, 0.022,0.527, -0.022,0.517,
       0.020,0.340, 0.040,0.285, -0.060,0.120, 0.080,0.020,
       0.000,0.085, 0.165,0.005],
      [0.025,0.945, 0.012,0.860, 0.015,0.832, -0.015,0.832,
       0.005,0.662, 0.005,0.662, 0.012,0.502, 0.010,0.500,
       0.000,0.530, 0.022,0.535, -0.022,0.525,
       0.080,0.330, 0.000,0.280, 0.060,0.110, 0.000,0.020,
       0.125,0.085, 0.085,0.005],
      [0.025,0.937, 0.012,0.852, 0.015,0.824, -0.015,0.824,
       -0.025,0.658, 0.030,0.660, -0.058,0.512, 0.060,0.515,
       0.000,0.522, 0.022,0.527, -0.022,0.517,
       0.100,0.300, -0.040,0.285, 0.140,0.050, -0.090,0.030,
       0.225,0.045, -0.010,0.005],
    ];

    /* fall — 5 keyframes: buckle, tilt, impact, collapse, settle */
    const FALL = [
      [-0.040,0.800, -0.030,0.720, -0.010,0.695, -0.050,0.690,
       0.020,0.555, -0.105,0.545, 0.045,0.425, -0.140,0.420,
       0.000,0.400, 0.022,0.405, -0.022,0.395,
       0.100,0.240, -0.020,0.220, 0.040,0.040, -0.060,0.030,
       0.120,0.015, 0.020,0.010],
      [-0.200,0.580, -0.160,0.505, -0.130,0.480, -0.180,0.460,
       -0.080,0.360, -0.260,0.355, -0.050,0.240, -0.320,0.235,
       0.000,0.260, 0.020,0.270, -0.020,0.250,
       0.100,0.160, -0.040,0.130, 0.080,0.030, -0.100,0.030,
       0.150,0.010, -0.030,0.010],
      [-0.310,0.300, -0.260,0.260, -0.230,0.250, -0.270,0.210,
       -0.160,0.180, -0.330,0.140, -0.120,0.080, -0.380,0.050,
       -0.020,0.140, 0.000,0.150, -0.040,0.130,
       0.100,0.100, 0.020,0.080, 0.180,0.040, 0.060,0.030,
       0.250,0.020, 0.120,0.010],
      [-0.400,0.070, -0.330,0.080, -0.300,0.100, -0.300,0.050,
       -0.210,0.130, -0.200,0.040, -0.120,0.150, -0.100,0.030,
       -0.010,0.080, 0.000,0.100, -0.010,0.060,
       0.120,0.110, 0.110,0.050, 0.230,0.090, 0.220,0.040,
       0.300,0.080, 0.290,0.030],
      [-0.410,0.060, -0.340,0.070, -0.310,0.090, -0.310,0.050,
       -0.220,0.120, -0.210,0.040, -0.130,0.140, -0.110,0.030,
       -0.010,0.070, 0.000,0.090, -0.010,0.050,
       0.120,0.100, 0.110,0.050, 0.230,0.080, 0.220,0.040,
       0.300,0.070, 0.290,0.030],
    ];

    const BONES = [
      [0, 1], [1, 2], [1, 3], [2, 4], [4, 6], [3, 5], [5, 7],
      [1, 8], [8, 9], [8, 10],
      [9, 11], [11, 13], [13, 15],
      [10, 12], [12, 14], [14, 16],
    ];

    /* ------------------- pose sampling ------------------------- */

    const pose = new Float64Array(34);
    const smooth = (f) => f * f * (3 - 2 * f);

    function lerpInto(A, B, f) {
      for (let i = 0; i < 34; i++) pose[i] = A[i] + (B[i] - A[i]) * f;
    }

    function sampleLoop(seq, u) {
      const n = seq.length;
      const x = (((u % 1) + 1) % 1) * n;
      const k = Math.floor(x) % n;
      lerpInto(seq[k], seq[(k + 1) % n], smooth(x - Math.floor(x)));
    }

    function sampleSeq(seq, p) {
      const n = seq.length - 1;
      const x = Math.max(0, Math.min(0.99999, p)) * n;
      const k = Math.floor(x);
      lerpInto(seq[k], seq[k + 1], smooth(x - k));
    }

    /* --------- left half: the 26×20 sensor mosaic --------------- */

    const TW = 26;
    const TH = 20;
    const tiny = document.createElement('canvas');
    tiny.width = TW;
    tiny.height = TH;
    const tctx = tiny.getContext('2d', { willReadFrequently: true });

    /* static per-block sensor pattern with a soft center vignette */
    const baseN = new Float32Array(TW * TH);
    for (let y = 0; y < TH; y++) {
      for (let x = 0; x < TW; x++) {
        const dx = (x - TW / 2) / TW;
        const dy = (y - TH / 2) / TH;
        baseN[y * TW + x] =
          8 + Math.random() * 24 + Math.max(0, 1 - Math.hypot(dx, dy) * 2) * 8;
      }
    }

    function drawTiny(flicker) {
      tctx.fillStyle = '#07080a';
      tctx.fillRect(0, 0, TW, TH);
      const tx = (j) => 13 + pose[j * 2] * 15;
      const ty = (j) => 18.5 - pose[j * 2 + 1] * 15.5;
      tctx.lineCap = 'round';
      // torso mass
      tctx.strokeStyle = 'rgb(110,110,114)';
      tctx.lineWidth = 3.2;
      tctx.beginPath();
      tctx.moveTo(tx(1), ty(1));
      tctx.lineTo(tx(8), ty(8));
      tctx.stroke();
      // limbs — the same bones the skeleton draws
      tctx.strokeStyle = 'rgb(128,128,133)';
      tctx.lineWidth = 1.7;
      tctx.beginPath();
      for (const [a, b] of BONES) {
        tctx.moveTo(tx(a), ty(a));
        tctx.lineTo(tx(b), ty(b));
      }
      tctx.stroke();
      // head
      tctx.fillStyle = 'rgb(152,152,157)';
      tctx.fillRect(tx(0) - 1.5, ty(0) - 2, 3, 3.5);
      // per-block sensor luminance noise
      const img = tctx.getImageData(0, 0, TW, TH);
      const d = img.data;
      for (let i = 0, k = 0; i < d.length; i += 4, k++) {
        const n = baseN[k] + (flicker ? Math.random() * 16 - 8 : 0);
        d[i] = Math.min(235, d[i] * 0.9 + n);
        d[i + 1] = Math.min(235, d[i + 1] * 0.9 + n);
        d[i + 2] = Math.min(238, d[i + 2] * 0.9 + n + 3);
      }
      tctx.putImageData(img, 0, 0);
    }

    /* --------------------- scene drawing ----------------------- */

    const jointGlow = glowSprite(lut[36], 48, 0.8);
    const beam = glowSprite(lut[150], 64, 0.9);
    const packetGlow = glowSprite(lut[200], 64, 1);
    const GATE1X = 0.865;
    const GATE2X = 0.935;

    function drawGate(ctx, x, H, bright) {
      const y0 = H * 0.12;
      const y1 = H * 0.86;
      if (bright > 0.03) {
        ctx.globalAlpha = Math.min(1, bright) * 0.7;
        ctx.drawImage(beam, x - 9, y0, 18, y1 - y0);
        ctx.globalAlpha = 1;
      }
      ctx.strokeStyle = lutColor(lut, 0.6, 0.16 + Math.min(1, bright) * 0.74);
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x + 0.5, y0);
      ctx.lineTo(x + 0.5, y1);
      ctx.stroke();
    }

    function drawScene(ctx, view, fx) {
      const { W, H } = view;
      ctx.clearRect(0, 0, W, H);

      // LEFT — what the camera sees: scaled-up unreadable mosaic
      ctx.imageSmoothingEnabled = false;
      ctx.drawImage(tiny, 0, 0, TW, TH, 0, 0, Math.round(W * 0.5), H);
      ctx.imageSmoothingEnabled = true;

      // the device boundary
      ctx.strokeStyle = 'rgba(233,230,223,0.38)';
      ctx.lineWidth = 1;
      ctx.setLineDash([5, 7]);
      ctx.beginPath();
      ctx.moveTo(W * 0.5 + 0.5, 8);
      ctx.lineTo(W * 0.5 + 0.5, H - 8);
      ctx.stroke();
      ctx.setLineDash([]);

      // RIGHT — what leaves: the identical pose as a clean skeleton
      const S = H * 0.62;
      const cx = W * 0.70;
      const gy = H * 0.84;
      const X = (j) => cx + pose[j * 2] * S;
      const Y = (j) => gy - pose[j * 2 + 1] * S;

      // ground
      ctx.strokeStyle = 'rgba(233,230,223,0.10)';
      ctx.beginPath();
      ctx.moveTo(W * 0.535, gy + 1.5);
      ctx.lineTo(W * 0.965, gy + 1.5);
      ctx.stroke();

      // the two gates — architecture is always visible
      drawGate(ctx, W * GATE1X, H, fx.g1);
      drawGate(ctx, W * GATE2X, H, fx.g2);

      // impact ring — fall event, alert color only
      if (fx.ring > 0 && fx.ring < 1) {
        const rr = 8 + fx.ring * 34;
        ctx.strokeStyle = `rgba(216,160,122,${(1 - fx.ring) * 0.55})`;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.ellipse(cx - 0.05 * S, gy, rr, rr * 0.32, 0, 0, Math.PI * 2);
        ctx.stroke();
      }

      // bones — 1.5px pearl strokes
      ctx.lineWidth = 1.5;
      ctx.lineCap = 'round';
      BONES.forEach(([a, b], i) => {
        ctx.strokeStyle = lutColor(
          lut,
          ((i / BONES.length) * 0.55 + fx.hue) % 1,
          0.85
        );
        ctx.beginPath();
        ctx.moveTo(X(a), Y(a));
        ctx.lineTo(X(b), Y(b));
        ctx.stroke();
      });

      // soft glow at head and hip center
      ctx.globalAlpha = 0.5;
      ctx.drawImage(jointGlow, X(0) - 9, Y(0) - 9, 18, 18);
      ctx.drawImage(jointGlow, X(8) - 9, Y(8) - 9, 18, 18);
      ctx.globalAlpha = 1;

      // joints — small filled circles from the pearl LUT
      for (let j = 0; j < 17; j++) {
        ctx.fillStyle = lutColor(lut, ((j / 17) * 0.8 + fx.hue) % 1, 1);
        ctx.beginPath();
        ctx.arc(X(j), Y(j), j === 0 ? 3.2 : 2.2, 0, Math.PI * 2);
        ctx.fill();
      }

      // the alert packet — the only thing that crosses out
      if (fx.packet >= 0 && fx.packet <= 1) {
        const px0 = W * GATE2X;
        const px1 = W * 0.985;
        const px = px0 + (px1 - px0) * fx.packet;
        const py = gy - 0.10 * S;
        ctx.globalAlpha = 0.9;
        ctx.drawImage(packetGlow, px - 10, py - 10, 20, 20);
        ctx.globalAlpha = 1;
        ctx.fillStyle = lutColor(lut, 0.8, 1);
        ctx.fillRect(px - 2, py - 2, 4, 4);
      }
    }

    /* ------------------ sequence state machine ----------------- */

    const CYCLE = 1150;
    const FALL_MS = 900;
    const DOWN_MS = 4000;
    const RISE_MS = 1300;
    const RISE_AT = FALL_MS + DOWN_MS;
    const G1_AT = 760;
    const G2_AT = 1360;
    const PKT_AT = 1450;
    const PKT_MS = 380;
    const CHIP_AT = 1840;

    let mode = 'walk';
    let clock = 0;
    let walkClock = 0;
    let seqAt = 0;
    let frame = 0;
    let nextAuto = 16000;
    let g1Done = false;
    let g2Done = false;
    let chipDone = false;
    let riseDone = false;
    let chipOn = false;
    let rmFallen = false;

    const fallSeq = [];
    const riseSeq = [FALL[4], FALL[2], FALL[0], WALK[2]];

    function setStatus(s) {
      if (statusEl) statusEl.textContent = s;
    }

    function litGate(el, on) {
      if (el) el.classList.toggle('lit', on);
    }

    function showChip(on) {
      if (!chipEl || chipOn === on) return;
      chipOn = on;
      if (on) {
        chipEl.textContent = CHIP_TEXT;
        chipEl.classList.add('show');
      } else {
        chipEl.classList.remove('show');
        setTimeout(() => {
          if (!chipOn) chipEl.textContent = '';
        }, 600);
      }
    }

    function triggerFall() {
      if (mode !== 'walk') return;
      sampleLoop(WALK, walkClock / CYCLE); // capture the live pose
      fallSeq.length = 0;
      fallSeq.push(Array.from(pose), ...FALL);
      mode = 'seq';
      seqAt = clock;
      g1Done = g2Done = chipDone = riseDone = false;
      if (btn) btn.disabled = true;
      setStatus('EVENT · CANDIDATE FALL');
    }

    function render(ctx, t, dt, view) {
      clock += dt;
      frame++;
      let g1 = 0;
      let g2 = 0;
      let ring = -1;
      let packet = -1;

      if (mode === 'walk') {
        walkClock += dt;
        sampleLoop(WALK, walkClock / CYCLE);
        if (clock >= nextAuto) triggerFall();
      }

      if (mode === 'seq') {
        const el = clock - seqAt;

        if (el < FALL_MS) {
          sampleSeq(fallSeq, el / FALL_MS);
        } else if (el < RISE_AT) {
          sampleSeq(fallSeq, 1); // holds still on the ground
        } else if (el < RISE_AT + RISE_MS) {
          if (!riseDone) {
            riseDone = true;
            showChip(false);
            litGate(gate1El, false);
            litGate(gate2El, false);
            setStatus('RECOVERED · RESUMING WATCH');
          }
          sampleSeq(riseSeq, (el - RISE_AT) / RISE_MS);
        } else {
          mode = 'walk';
          walkClock = CYCLE * 0.25;
          sampleLoop(WALK, 0.25);
          nextAuto = clock + 30000;
          if (btn) btn.disabled = false;
          setStatus('PIPELINE · NOMINAL');
        }

        if (!g1Done && el >= G1_AT) {
          g1Done = true;
          litGate(gate1El, true);
          setStatus('GATE 1 · MOTION TRIGGERED');
        }
        if (!g2Done && el >= G2_AT) {
          g2Done = true;
          litGate(gate2El, true);
          setStatus('GATE 2 · POSE CONFIRMED');
        }
        if (!chipDone && el >= CHIP_AT) {
          chipDone = true;
          showChip(true);
          setStatus('ALERT SENT · PIXELS STAYED HOME');
        }

        if (g1Done && !riseDone) g1 = 0.25 + 0.75 * Math.exp(-(el - G1_AT) / 450);
        if (g2Done && !riseDone) g2 = 0.25 + 0.75 * Math.exp(-(el - G2_AT) / 450);
        if (g1Done) {
          const rp = (el - G1_AT) / 700;
          if (rp < 1) ring = rp;
        }
        const pp = (el - PKT_AT) / PKT_MS;
        if (pp >= 0 && pp <= 1) packet = pp;
      }

      // governor: when degraded, refresh the mosaic every other frame
      if (!view.degraded || frame & 1) drawTiny(true);
      drawScene(ctx, view, { g1, g2, ring, packet, hue: t * 0.00002 });
    }

    function renderStill(ctx, view) {
      if (rmFallen) {
        lerpInto(FALL[4], FALL[4], 0); // composed fallen end-state
        drawTiny(false);
        drawScene(ctx, view, { g1: 0.85, g2: 0.85, ring: -1, packet: -1, hue: 0 });
      } else {
        sampleLoop(WALK, 0.02); // composed mid-stride frame
        drawTiny(false);
        drawScene(ctx, view, { g1: 0, g2: 0, ring: -1, packet: -1, hue: 0 });
      }
    }

    const sim = makeSim(c, { render, renderStill });

    if (btn) {
      btn.addEventListener('click', () => {
        if (reducedMotion) {
          // no tweening — jump straight between the two end-states
          rmFallen = !rmFallen;
          litGate(gate1El, rmFallen);
          litGate(gate2El, rmFallen);
          showChip(rmFallen);
          setStatus(rmFallen ? 'ALERT SENT · PIXELS STAYED HOME' : 'PIPELINE · NOMINAL');
          btn.textContent = rmFallen ? 'Reset — stand back up' : 'Simulate a fall';
          sim.restart();
        } else {
          triggerFall();
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initEmote4d);
</script>
