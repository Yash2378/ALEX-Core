---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Multivac Physics · Deep Pearl"
  description="Graduate level physics problems run through the same blind peer matrix, measured across model families."
>
  <article class="thread-page wrap">
    <a class="back" href="/">
      <span aria-hidden="true">&larr;</span>
      <span>Deep Pearl</span>
    </a>

    <div class="meta-row">
      <span class="tag tag-live">Live</span>
    </div>
    <h1>Multivac Physics</h1>
    <p class="lede">Graduate level physics problems run through the same blind peer matrix, measured across model families.</p>

    <div class="research-groups">
      <section class="research-group" aria-labelledby="g-phys">
        <h2 id="g-phys">Research topics</h2>
        <ul class="studying-list">
          <li>physics evaluation</li>
          <li>cross family confirmation</li>
        </ul>
      </section>
    </div>
  </article>
</Layout>
