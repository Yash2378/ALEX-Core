---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Research lab</p>
      <h1>Deep Pearl</h1>
      <p class="lede">A research lab studying AI evaluation, judgment, and edge intelligence.</p>
      <dl class="meta">
        <div>
          <dt>Focus</dt>
          <dd>Evaluation independence</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>Active research</dd>
        </div>
        <div>
          <dt>Home</dt>
          <dd>deeppearlai.com</dd>
        </div>
      </dl>
    </div>
  </section>

  <section id="research" class="section">
    <div class="wrap">
      <header class="section-header">
        <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Research</p>
        <h2>Threads</h2>
        <p class="kicker">Open lines of work at Deep Pearl. Each thread carries its own status and pace.</p>
      </header>
      <div class="threads">
        <article class="thread">
          <div class="thread-content">
            <header class="thread-head">
              <span class="tag tag-review">Under review</span>
              <h3>Evaluation and judgment</h3>
            </header>
            <p>Independent evaluation of language models, and how a benchmark's design shapes its rankings.</p>
            <ul class="topic-tags" aria-label="Topics">
              <li>evaluation independence</li>
              <li>constructor bias</li>
              <li>same vendor judge bias</li>
            </ul>
          </div>
          <a class="thread-link" href="/multivac">
            <span>Read progress</span>
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </article>
        <article class="thread">
          <div class="thread-content">
            <header class="thread-head">
              <span class="tag tag-live">Live</span>
              <h3>Physics evaluation</h3>
            </header>
            <p>Graduate level physics problems run through the same blind peer matrix, measured across model families.</p>
            <ul class="topic-tags" aria-label="Topics">
              <li>physics evaluation</li>
              <li>cross family confirmation</li>
            </ul>
          </div>
          <a class="thread-link" href="https://multivacphysics.com" target="_blank" rel="noopener">
            <span>Visit site</span>
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </article>
        <article class="thread">
          <div class="thread-content">
            <header class="thread-head">
              <span class="tag tag-active">Active prototype</span>
              <h3>Adaptive edge intelligence</h3>
            </header>
            <p>An assistant that runs on the device, keeps personal data local, and learns from everyday use.</p>
            <ul class="topic-tags" aria-label="Topics">
              <li>representation learning</li>
              <li>interpretability</li>
              <li>adaptive computation</li>
              <li>edge deployment</li>
              <li>robotic integration</li>
            </ul>
          </div>
          <a class="thread-link" href="/edge">
            <span>Open thread</span>
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </article>
        <article class="thread">
          <div class="thread-content">
            <header class="thread-head">
              <span class="tag tag-pilot">In pilot</span>
              <h3>Fall detection at the edge</h3>
            </header>
            <p>On device computer vision that detects falls in eldercare without sending video away.</p>
            <ul class="topic-tags" aria-label="Topics">
              <li>representation learning</li>
              <li>adaptive computation</li>
              <li>edge deployment</li>
            </ul>
          </div>
          <a class="thread-link" href="https://emote4d.com" target="_blank" rel="noopener">
            <span>Visit site</span>
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </article>
      </div>

      <div class="studying">
        <p class="label">Open questions Deep Pearl is reading into</p>
        <ul class="studying-list">
          <li>representation learning</li>
          <li>interpretability</li>
          <li>adaptive computation</li>
          <li>edge deployment</li>
          <li>robotic integration</li>
        </ul>
      </div>

      <aside class="influences">
        <p class="label">Influences</p>
        <p>World model and edge AI research by the author of <a href="https://github.com/yuedajiong" rel="noopener">github.com/yuedajiong</a>.</p>
      </aside>
    </div>
  </section>

  <section id="papers" class="section">
    <div class="wrap">
      <header class="section-header">
        <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Papers</p>
        <h2>Working list</h2>
      </header>
      <ul class="papers">
        <li>
          <div class="paper-row">
            <h3>Multivac evaluation methodology</h3>
            <span class="tag tag-review">Under review</span>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <section id="demos" class="section">
    <div class="wrap">
      <header class="section-header">
        <p class="eyebrow"><span class="bar" aria-hidden="true"></span>Demos</p>
        <h2>Interactive research</h2>
        <p class="kicker">Demos for active threads. Entries to follow.</p>
      </header>
      <div class="demo-grid" aria-hidden="true">
        <div class="demo-card"></div>
        <div class="demo-card"></div>
        <div class="demo-card"></div>
        <div class="demo-card"></div>
      </div>
    </div>
  </section>
</Layout>
