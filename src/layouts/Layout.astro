---
import '../styles/global.css';
const {
  title = 'Deep Pearl',
  description = 'Deep Pearl is a research lab studying AI evaluation, judgment, and edge intelligence.',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/og.png', Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    <meta name="color-scheme" content="dark" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:site_name" content="Deep Pearl" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Deep Pearl" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Deep Pearl" />

    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap">
        <a href="/" class="wordmark" aria-label="Deep Pearl home">
          <span class="dot" aria-hidden="true"></span>
          <span>Deep Pearl</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/#research">Research</a>
          <a href="/#papers">Papers</a>
          <a href="/multivac">Multivac</a>
          <a href="/#demos">Demos</a>
        </nav>
      </div>
    </header>
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <span>Deep Pearl. Independent research.</span>
        <span>deeppearlai.com</span>
      </div>
    </footer>
  </body>
</html>
